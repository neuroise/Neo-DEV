# NEUROISE Playground - Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ==============================================================================
# LLM API Keys (optional - only needed if using cloud models)
# ==============================================================================

# Anthropic Claude API (optional, for Claude models)
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI API (optional, for GPT models)
# OPENAI_API_KEY=sk-xxxxx

# ==============================================================================
# Ollama Settings
# ==============================================================================

# Ollama server URL (auto-configured by Docker, no need to change)
OLLAMA_HOST=http://localhost:11434

# Default model for generation
OLLAMA_DEFAULT_MODEL=llama3.3:70b

# ==============================================================================
# Video Generation Service
# ==============================================================================

# Video generation service URL (auto-configured by Docker in production)
VIDEO_GEN_URL=http://video-gen:8000

# ==============================================================================
# Application Settings
# ==============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Data directory (relative to app root)
DATA_DIR=./data

# Enable experiment tracking
ENABLE_TRACKING=true

# ==============================================================================
# Development Settings
# ==============================================================================

# Enable debug mode
DEBUG=false

# Hot reload for Streamlit
STREAMLIT_FILE_WATCHER_TYPE=poll
