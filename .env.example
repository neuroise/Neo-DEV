# NEURØISE Playground - Environment Variables
#
# Copy this file to .env and fill in your values
# cp .env.example .env

# ==============================================================================
# LLM API Keys
# ==============================================================================

# Anthropic Claude API (required for Claude models)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI API (required for GPT models)
OPENAI_API_KEY=sk-xxxxx

# ==============================================================================
# Ollama Settings
# ==============================================================================

# Ollama server URL (default: localhost for Mac, ollama service for Docker)
OLLAMA_HOST=http://localhost:11434

# Default model for Ollama
OLLAMA_DEFAULT_MODEL=llama3.2:8b

# ==============================================================================
# Video Generation APIs (Stage 2)
# ==============================================================================

# Runway Gen-3 API
# RUNWAY_API_KEY=xxxxx

# Pika Labs API
# PIKA_API_KEY=xxxxx

# ==============================================================================
# Music Generation APIs (Stage 2)
# ==============================================================================

# Suno API
# SUNO_API_KEY=xxxxx

# ==============================================================================
# Application Settings
# ==============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Data directory (relative to app root)
DATA_DIR=./data

# Enable experiment tracking
ENABLE_TRACKING=true

# ==============================================================================
# Development Settings
# ==============================================================================

# Enable debug mode
DEBUG=false

# Hot reload for Streamlit
STREAMLIT_FILE_WATCHER_TYPE=poll
