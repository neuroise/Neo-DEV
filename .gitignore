# NEUROISE Playground - .gitignore

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/

# ============================================================================
# Environment & Secrets
# ============================================================================
.env
*.pem
*.key

# ============================================================================
# Runtime data (generated at runtime, not tracked)
# ============================================================================
data/outputs/*
!data/outputs/.gitkeep
!data/outputs/videos/
data/outputs/videos/*
!data/outputs/videos/.gitkeep
data/logs/*
!data/logs/.gitkeep

# ============================================================================
# Model weights & caches
# ============================================================================
models/
*.bin
*.safetensors
*.gguf
.cache/

# ============================================================================
# IDE & OS
# ============================================================================
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~
.ipynb_checkpoints/

# ============================================================================
# Docker
# ============================================================================
docker-compose.override.yml
